<Window x:Class="WindowMonitor.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowMonitor.UI"
        mc:Ignorable="d"
        Title="Windows桌面窗口监控" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <ToolBar Grid.Row="0" Margin="5">
            <Button Content="开始监控" Command="{Binding StartMonitoringCommand}" 
                    Padding="10,5" Margin="2"/>
            <Button Content="停止监控" Command="{Binding StopMonitoringCommand}" 
                    Padding="10,5" Margin="2"/>
            <Button Content="暂停/继续" Command="{Binding PauseMonitoringCommand}" 
                    Padding="10,5" Margin="2"/>
            <Separator/>
            <Button Content="刷新窗口" Command="{Binding RefreshWindowsCommand}" 
                    Padding="10,5" Margin="2"/>
            <Separator/>
            <Button Content="选择目标窗口" Command="{Binding SelectTargetWindowCommand}" 
                    Padding="10,5" Margin="2" Background="#FFF0E68C"/>
            <Button Content="监控所有窗口" Command="{Binding MonitorAllWindowsCommand}" 
                    Padding="10,5" Margin="2"/>
            <Separator/>
            <Button Content="清空日志" Command="{Binding ClearLogsCommand}" 
                    Padding="10,5" Margin="2"/>
            <Button Content="导出日志" Command="{Binding ExportLogsCommand}" 
                    Padding="10,5" Margin="2" Background="#FF87CEEB"/>
        </ToolBar>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：当前窗口列表 -->
            <GroupBox Grid.Column="0">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="当前窗口"/>
                        <TextBlock Text="  |  监控模式: "/>
                        <TextBlock x:Name="MonitorModeTextBlock">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="全部窗口"/>
                                    <Setter Property="Foreground" Value="Gray"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MonitoringSingleWindow}" Value="True">
                                            <Setter Property="Text" Value="单个窗口"/>
                                            <Setter Property="Foreground" Value="Orange"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </GroupBox.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 目标窗口信息 -->
                    <GroupBox Header="目标窗口" Grid.Row="0" Margin="0,0,0,5" Padding="5">
                        <TextBlock Text="{Binding TargetWindow.Title, FallbackValue='未选择'}" 
                                   FontStyle="Italic" Foreground="Gray"/>
                    </GroupBox>
                    
                    <!-- 窗口列表 -->
                    <DataGrid x:Name="WindowsDataGrid" 
                              ItemsSource="{Binding CurrentWindows}"
                              SelectedItem="{Binding SelectedWindow}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              Grid.Row="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="标题" Binding="{Binding Title}" Width="*"/>
                            <DataGridTextColumn Header="进程" Binding="{Binding ProcessName}" Width="100"/>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Hwnd}" Value="{Binding DataContext.TargetWindow.Hwnd, RelativeSource={RelativeSource AncestorType=DataGrid}}">
                                        <Setter Property="Background" Value="#FFEEDC82"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </Grid>
            </GroupBox>

            <!-- 分隔条 -->
            <GridSplitter Grid.Column="1" 
                          Width="5" 
                          HorizontalAlignment="Stretch"
                          Background="Gray"/>

            <!-- 右侧：日志列表 -->
            <GroupBox Header="监控日志" Grid.Column="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="LogsDataGrid" 
                              ItemsSource="{Binding LogEntries}"
                              SelectedItem="{Binding SelectedLogEntry}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              Grid.Row="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="时间" Binding="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss.fff'}" Width="160"/>
                            <DataGridTextColumn Header="事件类型" Binding="{Binding EventType}" Width="120"/>
                            <DataGridTextColumn Header="窗口标题" Binding="{Binding WindowTitle}" Width="*"/>
                            <DataGridTextColumn Header="进程" Binding="{Binding ProcessName}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- 日志详情面板 -->
                    <GroupBox Header="AI分析用日志详情" Grid.Row="1" Margin="0,5,0,0" Height="240">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 快速信息 -->
                                <StackPanel Grid.Row="0" Orientation="Vertical" Margin="5">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontWeight="Bold" Text="摘要: " Width="80"/>
                                        <TextBlock Text="{Binding SelectedLogEntry.ContextSummary}" Foreground="Blue"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBlock FontWeight="Bold" Text="分析提示: " Width="80"/>
                                        <TextBlock Text="{Binding SelectedLogEntry.AnalysisHint}" Foreground="DarkGreen"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <!-- 详细信息（AI友好格式） -->
                                <TextBlock x:Name="LogDetailsTextBlock" 
                                           Grid.Row="1"
                                           TextWrapping="Wrap"
                                           Padding="5"
                                           FontFamily="Consolas"
                                           FontSize="11">
                                    <Run Text="=== 窗口事件日志 ==="/><LineBreak/>
                                    <Run Text="时间: "/><Run Text="{Binding SelectedLogEntry.Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss.fff'}"/><LineBreak/>
                                    <Run Text="事件类型: "/><Run Text="{Binding SelectedLogEntry.EventType}"/><LineBreak/>
                                    <Run Text="日志级别: "/><Run Text="{Binding SelectedLogEntry.Level}"/><LineBreak/>
                                    <LineBreak/>
                                    <Run Text="--- 窗口信息 ---"/><LineBreak/>
                                    <Run Text="标题: "/><Run Text="{Binding SelectedLogEntry.WindowTitle}"/><LineBreak/>
                                    <Run Text="类名: "/><Run Text="{Binding SelectedLogEntry.ClassName}"/><LineBreak/>
                                    <Run Text="句柄: "/><Run Text="{Binding SelectedLogEntry.Hwnd}"/><LineBreak/>
                                    <Run Text="父窗口: "/><Run Text="{Binding SelectedLogEntry.ParentHwnd}"/><LineBreak/>
                                    <LineBreak/>
                                    <Run Text="--- 进程信息 ---"/><LineBreak/>
                                    <Run Text="进程名: "/><Run Text="{Binding SelectedLogEntry.ProcessName}"/><LineBreak/>
                                    <Run Text="进程ID: "/><Run Text="{Binding SelectedLogEntry.ProcessId}"/><LineBreak/>
                                    <Run Text="线程ID: "/><Run Text="{Binding SelectedLogEntry.ThreadId}"/><LineBreak/>
                                    <LineBreak/>
                                    <Run Text="--- 位置和尺寸 ---"/><LineBreak/>
                                    <Run Text="位置: (X:"/><Run Text="{Binding SelectedLogEntry.Left}"/><Run Text=", Y:"/><Run Text="{Binding SelectedLogEntry.Top}"/><Run Text=")"/><LineBreak/>
                                    <Run Text="大小: "/><Run Text="{Binding SelectedLogEntry.Width}"/><Run Text="x"/><Run Text="{Binding SelectedLogEntry.Height}"/><LineBreak/>
                                    <Run Text="边界: [L:"/><Run Text="{Binding SelectedLogEntry.Left}"/><Run Text=", T:"/><Run Text="{Binding SelectedLogEntry.Top}"/><Run Text=", R:"/><Run Text="{Binding SelectedLogEntry.Right}"/><Run Text=", B:"/><Run Text="{Binding SelectedLogEntry.Bottom}"/><Run Text="]"/><LineBreak/>
                                    <LineBreak/>
                                    <Run Text="--- 状态 ---"/><LineBreak/>
                                    <Run Text="可见: "/><Run Text="{Binding SelectedLogEntry.Visible}"/><LineBreak/>
                                    <Run Text="活跃: "/><Run Text="{Binding SelectedLogEntry.Active}"/><LineBreak/>
                                    <LineBreak/>
                                    <Run Text="--- AI分析上下文 ---"/><LineBreak/>
                                    <Run Text="摘要: "/><Run Text="{Binding SelectedLogEntry.ContextSummary}"/><LineBreak/>
                                    <Run Text="分析提示: "/><Run Text="{Binding SelectedLogEntry.AnalysisHint}"/>
                                </TextBlock>
                            </Grid>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="2" Margin="0,5,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="状态: "/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="StateTextBlock">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MonitorState}" Value="Stopped">
                                    <Setter Property="Text" Value="已停止"/>
                                    <Setter Property="Foreground" Value="Gray"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding MonitorState}" Value="Running">
                                    <Setter Property="Text" Value="运行中"/>
                                    <Setter Property="Foreground" Value="Green"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding MonitorState}" Value="Paused">
                                    <Setter Property="Text" Value="已暂停"/>
                                    <Setter Property="Foreground" Value="Orange"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="窗口数量: "/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding CurrentWindows.Count}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="日志数量: "/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding LogEntries.Count}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
